  </svg>

  <!-- particles -->
  <div id="spParticles"></div>

  <div class="sp-orb">
    <div class="sp-orb-ring"></div>
    <div class="sp-orb-ring"></div>
    <div class="sp-orb-ring"></div>
    <div class="sp-orb-core">
      <svg viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
