let firingActive=false;
async function fireAll(){
  if(firingActive) return;
  firingActive=true;
  const btn=g2('fireBtn'); if(btn){btn.disabled=true;btn.textContent='⏳ Firing…';}
  const url=g2('mUrl')?.value.trim();
  g('progWrap',e=>e.style.display='');
  g('progFill',e=>e.style.width='0%');
  g('progTxt',e=>e.textContent='0/'+slots.length);
  slots.forEach(s=>setSlotStatus(s.id,'pending'));
  const conc=parseInt(g2('mConc')?.value)||5;
  let done=0; const t0=performance.now();
  notify('Firing',slots.length+' requests · '+conc+' concurrent','info',3000);
  const queue=[...slots];
  async function worker(){while(queue.length){const s=queue.shift();await fireSlot(s,url);done++;g('progFill',e=>e.style.width=Math.round(done/slots.length*100)+'%');g('progTxt',e=>e.textContent=done+'/'+slots.length+' done');}}
  await Promise.all(Array.from({length:Math.min(conc,slots.length)},()=>worker()));
  const okN=slots.filter(s=>s.status==='ok').length;
  notify('Batch Complete',`${okN}/${slots.length} succeeded · ${Math.round(performance.now()-t0)}ms total`,okN===slots.length?'ok':'warn',5000);
  if(btn){btn.disabled=false;btn.textContent='⚡ Fire All';}
  firingActive=false;
}
async function fireSlot(s,url){
  const ta=g2('slotTA_'+s.id);
  let payload; try{payload=JSON.parse(ta?.value);}catch{setSlotDone(s.id,false,null,'Invalid JSON',0);return;}
  if(payload.data?.clientTxnId) payload.data.clientTxnId+='-'+Date.now()+'-'+s.id;
  const t1=performance.now();
  try{
    const resp=await fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    const ms=Math.round(performance.now()-t1);
    const text=await resp.text();
    let parsed; try{parsed=JSON.parse(text);}catch{}
    setSlotDone(s.id,resp.ok,resp.status,parsed||text,ms);
    recordStat(resp.ok,ms,CH_LABELS[s.ch]||s.ch,resp.status);
  }catch(e){
    const ms=Math.round(performance.now()-t1);
    setSlotDone(s.id,false,null,'⚠ '+e.message+'\n\nURL: '+url,ms);
    recordStat(false,ms,CH_LABELS[s.ch]||s.ch,null);
  }
}
function setSlotStatus(id,status){
