      <circle cx="900" cy="150" r="4" fill="#7e22ce" stroke="none" opacity=".7"/>
      <circle cx="200" cy="400" r="4" fill="#9333ea" stroke="none" opacity=".7"/>
      <circle cx="500" cy="450" r="4" fill="#c084fc" stroke="none" opacity=".6"/>
      <circle cx="800" cy="350" r="4" fill="#7e22ce" stroke="none" opacity=".8"/>
      <circle cx="450" cy="600" r="4" fill="#9333ea" stroke="none" opacity=".6"/>
      <circle cx="750" cy="750" r="4" fill="#c084fc" stroke="none" opacity=".7"/>
