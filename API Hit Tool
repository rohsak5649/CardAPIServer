        <circle cx="16" cy="13.25" r="2" fill="white" opacity=".95"/>
      </svg>
    </div>
  </div>

  <div class="sp-wordmark">Card<span>API</span></div>
  <div class="sp-sub">Payment Switching Engine v3.2</div>

  <div class="sp-steps" id="spSteps"></div>

  <div class="sp-bar-wrap"><div class="sp-bar" id="spBar"></div></div>
  <div class="sp-ver">© 2026 · CardEngine Platform</div>
</div>

<!-- ═══ NOTIFICATIONS ═══ -->
<div id="notifs"></div>

<!-- ═══ TOPBAR ═══ -->
<div class="topbar" id="topbar" style="display:none">
  <div class="logo">
    <div class="logo-mark">
      <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="1" y="3" width="14" height="10" rx="2" stroke="white" stroke-width="1.2"/>
        <path d="M1 6.5h14" stroke="white" stroke-width="1.2"/>
        <rect x="2.5" y="9" width="4" height="1.8" rx=".6" fill="white" opacity=".9"/>
        <circle cx="12" cy="9.9" r="1.6" fill="white" opacity=".95"/>
      </svg>
    </div>
    <span class="logo-text">Card<span>API</span></span>
    <span class="logo-badge">v3.2</span>
  </div>
  <div class="tb-div"></div>
  <div class="engine-pill" onclick="pingHealth()" title="Click to re-ping">
    <div class="eng-dot chk" id="engDot"></div>
    <span class="eng-txt" id="engLbl">Checking…</span>
  </div>
  <div class="tb-div"></div>
  <span class="tb-stat">Req <b id="sTot">0</b></span>
  <span class="tb-stat">OK <b id="sOk" style="color:var(--ok)">0</b></span>
  <span class="tb-stat">ERR <b id="sErr" style="color:var(--err)">0</b></span>
  <div class="spacer"></div>
  <div class="env-sw">
    <button class="env-btn on" onclick="setEnv('DEV',this)">DEV</button>
    <button class="env-btn" onclick="setEnv('UAT',this)">UAT</button>
    <button class="env-btn" onclick="setEnv('PROD',this)">PROD</button>
  </div>
  <button class="tb-btn" onclick="togglePanel()">⊡ Panel</button>
  <button class="tb-btn" onclick="clearAll()">✕ Clear</button>
</div>

<!-- ═══ APP ═══ -->
<div class="app" id="app" style="display:none">

  <!-- SIDEBAR -->
  <div class="sidebar" id="sidebar">
    <div class="sb-hd">
      <span class="sb-title">Endpoints</span>
    </div>
    <div class="sb-search-wrap">
      <div class="sb-search">
        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1.4"/><path d="M10.5 10.5L13 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
        <input id="sbSearch" placeholder="Search…" oninput="filterSb(this.value)"/>
      </div>
    </div>

    <div class="sb-list" id="sbList">
      <div class="workflow-banner">
        <b>⚠ WORKFLOW</b>
        1. Issue card (ISSUER)<br>
        2. Copy encryptedPan + expiry<br>
        3. Use in all transactions<br>
        4. Generate PIN offline
      </div>

      <div class="sb-sec">Card</div>
      <div class="sb-item act" id="si_ISSUER" onclick="goSingle('ISSUER')">
        <span class="sb-dot" style="background:#ec4899"></span><span class="sb-lbl">Issue New Card</span><span class="mpost sb-method">POST</span>
      </div>
      <div class="sb-item" id="si_CARD_DETAILS" onclick="goSingle('CARD_DETAILS')">
        <span class="sb-dot" style="background:#9b59fc"></span><span class="sb-lbl">Card Details</span><span class="mpost sb-method">POST</span>
      </div>
      <div class="sb-item" id="si_CARD_ACTIVATE" onclick="goSingle('CARD_ACTIVATE')">
        <span class="sb-dot" style="background:#10b981"></span><span class="sb-lbl">Activate Card</span><span class="mpost sb-method">POST</span>
      </div>
      <div class="sb-item" id="si_CARD_BLOCK" onclick="goSingle('CARD_BLOCK')">
        <span class="sb-dot" style="background:#ef4444"></span><span class="sb-lbl">Block Card</span><span class="mpost sb-method">POST</span>
      </div>
      <div class="sb-item" id="si_CARD_SET_LIMIT" onclick="goSingle('CARD_SET_LIMIT')">
        <span class="sb-dot" style="background:#f59e0b"></span><span class="sb-lbl">Set Card Limit</span><span class="mpost sb-method">POST</span>
      </div>
      <div class="sb-item" id="si_CARD_RESET_PIN" onclick="goSingle('CARD_RESET_PIN')">
        <span class="sb-dot" style="background:#8b5cf6"></span><span class="sb-lbl">Reset PIN</span><span class="mpost sb-method">POST</span>
      </div>

      <div class="sb-sec">Accounts</div>
      <div class="sb-item" id="si_accounts" onclick="switchMode('accounts')">
        <span class="sb-dot" style="background:#10b981"></span><span class="sb-lbl">Manage Accounts</span><span class="sb-tag">PANEL</span>
      </div>

      <div class="sb-sec">ATM</div>
      <div class="sb-item" id="si_ATM_WITHDRAWAL" onclick="goSingle('ATM_WITHDRAWAL')">
        <span class="sb-dot" style="background:#f59e0b"></span><span class="sb-lbl">ATM Withdrawal</span><span class="mpost sb-method">POST</span>
      </div>
      <div class="sb-item" id="si_ATM_DEPOSIT" onclick="goSingle('ATM_DEPOSIT')">
        <span class="sb-dot" style="background:#f59e0b"></span><span class="sb-lbl">ATM Deposit</span><span class="mpost sb-method">POST</span>
      </div>

      <div class="sb-sec">POS</div>
      <div class="sb-item" id="si_POS_PURCHASE" onclick="goSingle('POS_PURCHASE')">
        <span class="sb-dot" style="background:#22c55e"></span><span class="sb-lbl">POS Purchase</span><span class="mpost sb-method">POST</span>
      </div>
      <div class="sb-item" id="si_POS_REFUND" onclick="goSingle('POS_REFUND')">
        <span class="sb-dot" style="background:#22c55e"></span><span class="sb-lbl">POS Refund</span><span class="mpost sb-method">POST</span>
      </div>

