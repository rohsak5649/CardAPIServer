<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>CardAPI — Payment Switching Engine v3.2</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════ TOKENS ══════════════════════════ */
:root{
  --p50:#faf5ff; --p100:#f3e8ff; --p200:#e9d5ff; --p300:#d8b4fe;
  --p400:#c084fc; --p500:#a855f7; --p600:#9333ea; --p700:#7e22ce;
  --p800:#6b21a8; --p900:#581c87;
  --bg:#ffffff; --bg2:#fafafa; --bg3:#f4f4f8;
  --border:#e8e0f5; --border2:#d4c6f0;
  --text:#1a0a2e; --text2:#6b5f87; --text3:#a998c4;
  --ok:#16a34a; --ok-bg:#dcfce7; --ok-border:#bbf7d0;
  --err:#dc2626; --err-bg:#fee2e2; --err-border:#fca5a5;
  --warn:#d97706; --warn-bg:#fef3c7;
  --mono:'Geist Mono',monospace;
  --sans:'Outfit',sans-serif;
  --radius:10px;
  --shadow:0 1px 3px rgba(88,28,135,0.08),0 4px 16px rgba(88,28,135,0.06);
  --shadow2:0 2px 8px rgba(88,28,135,0.12),0 8px 32px rgba(88,28,135,0.1);
}

/* ══════════════════════════ RESET ══════════════════════════ */
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:var(--sans);font-size:13px;-webkit-font-smoothing:antialiased}

/* ══════════════════════════ SPLASH ══════════════════════════ */
#splash{
  position:fixed;inset:0;z-index:9999;
  background:#0d0014;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  overflow:hidden;
  transition:opacity .6s ease, visibility .6s ease;
}
#splash.gone{opacity:0;visibility:hidden;pointer-events:none}

/* circuit lines */
.circuit-bg{position:absolute;inset:0;pointer-events:none}
.circuit-bg svg{width:100%;height:100%;opacity:0;animation:circuitFade 1.2s .5s forwards}
@keyframes circuitFade{to{opacity:1}}

/* orb */
.sp-orb{
  position:relative;width:120px;height:120px;
  display:flex;align-items:center;justify-content:center;
  z-index:2;
}
.sp-orb-ring{
  position:absolute;border-radius:50%;border:1.5px solid;
  animation:orbPulse 2.5s ease-in-out infinite;
}
.sp-orb-ring:nth-child(1){width:120px;height:120px;border-color:rgba(168,85,247,0.5);animation-delay:0s}
.sp-orb-ring:nth-child(2){width:90px;height:90px;border-color:rgba(168,85,247,0.4);animation-delay:.3s}
.sp-orb-ring:nth-child(3){width:60px;height:60px;border-color:rgba(168,85,247,0.6);animation-delay:.6s}
@keyframes orbPulse{
  0%,100%{transform:scale(1);opacity:.6}
  50%{transform:scale(1.12);opacity:1}
}
.sp-orb-core{
  width:44px;height:44px;border-radius:50%;
  background:radial-gradient(circle at 30% 30%,#e9d5ff,#7e22ce);
  box-shadow:0 0 30px rgba(168,85,247,0.8),0 0 60px rgba(168,85,247,0.4);
  z-index:1;position:relative;
  display:flex;align-items:center;justify-content:center;
  animation:coreGlow 2s ease-in-out infinite alternate;
}
@keyframes coreGlow{
  from{box-shadow:0 0 20px rgba(168,85,247,0.6),0 0 40px rgba(168,85,247,0.3)}
  to{box-shadow:0 0 40px rgba(192,132,252,1),0 0 80px rgba(168,85,247,0.6)}
}
.sp-orb-core svg{width:22px;height:22px;opacity:.9}

/* text */
.sp-wordmark{
  font-size:38px;font-weight:800;letter-spacing:-2px;color:#fff;
  margin-top:20px;z-index:2;
  animation:wordIn .8s .3s cubic-bezier(.175,.885,.32,1.275) both;
}
.sp-wordmark span{color:#c084fc}
@keyframes wordIn{from{opacity:0;transform:translateY(20px) scale(.95)}to{opacity:1;transform:none}}
.sp-sub{
  font-family:var(--mono);font-size:11px;letter-spacing:3px;color:rgba(192,132,252,0.7);
  text-transform:uppercase;margin-top:8px;z-index:2;
  animation:wordIn .8s .5s both;
}
.sp-steps{
  display:flex;flex-direction:column;gap:6px;margin-top:28px;
  font-family:var(--mono);font-size:10px;z-index:2;width:260px;
  animation:wordIn .8s .7s both;
}
.sp-step{
  display:flex;align-items:center;gap:8px;color:rgba(255,255,255,.3);
  transition:color .4s;padding:4px 0;
}
.sp-step.done{color:rgba(192,132,252,.9)}
.sp-step.active{color:#fff}
.sp-step-dot{
  width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.15);
  flex-shrink:0;transition:all .4s;
}
.sp-step.done .sp-step-dot{background:#a855f7;box-shadow:0 0 6px #a855f7}
.sp-step.active .sp-step-dot{background:#fff;box-shadow:0 0 8px #fff;animation:dotBlink .6s infinite}
@keyframes dotBlink{0%,100%{opacity:1}50%{opacity:.3}}
.sp-bar-wrap{
  width:260px;height:2px;background:rgba(255,255,255,.08);border-radius:1px;
  margin-top:20px;overflow:hidden;z-index:2;
  animation:wordIn .8s .9s both;
}
.sp-bar{height:100%;width:0%;background:linear-gradient(90deg,#7e22ce,#c084fc);border-radius:1px;transition:width .2s linear}
.sp-ver{position:absolute;bottom:20px;font-family:var(--mono);font-size:9px;color:rgba(168,85,247,.4);z-index:2}

/* particles */
.particle{position:absolute;border-radius:50%;pointer-events:none;animation:particleDrift linear infinite}
@keyframes particleDrift{
  0%{transform:translateY(100vh) scale(0);opacity:0}
  10%{opacity:1}
  90%{opacity:1}
  100%{transform:translateY(-100px) scale(1);opacity:0}
}

/* ══════════════════════════ TOPBAR ══════════════════════════ */
.topbar{
  height:48px;display:flex;align-items:center;gap:10px;
  padding:0 16px;
  background:#fff;
  border-bottom:1px solid var(--border);
  box-shadow:0 1px 0 var(--border);
  position:relative;z-index:200;flex-shrink:0;
}
.logo{display:flex;align-items:center;gap:8px;flex-shrink:0;text-decoration:none}
.logo-mark{
  width:28px;height:28px;border-radius:8px;
  background:linear-gradient(135deg,var(--p700),var(--p500));
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 2px 8px rgba(126,34,206,.3);
}
.logo-mark svg{width:16px;height:16px}
.logo-text{font-size:15px;font-weight:800;color:var(--text);letter-spacing:-.5px}
.logo-text span{color:var(--p600)}
.logo-badge{font-size:8px;padding:1px 5px;border-radius:4px;background:var(--p100);color:var(--p700);font-family:var(--mono);font-weight:600;border:1px solid var(--p200)}
.tb-div{width:1px;height:20px;background:var(--border);flex-shrink:0}
.engine-pill{
  display:flex;align-items:center;gap:6px;padding:4px 10px;
  background:var(--bg2);border:1px solid var(--border);border-radius:20px;
  cursor:pointer;transition:all .2s;flex-shrink:0;
}
.engine-pill:hover{border-color:var(--border2);background:var(--p50)}
.eng-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;transition:all .3s}
.eng-dot.up{background:var(--ok);box-shadow:0 0 6px rgba(22,163,74,.4)}
.eng-dot.down{background:var(--err);box-shadow:0 0 6px rgba(220,38,38,.4)}
.eng-dot.chk{background:var(--warn);animation:blink 1s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.eng-txt{font-family:var(--mono);font-size:9px;color:var(--text2);white-space:nowrap}
.tb-stat{font-family:var(--mono);font-size:9px;color:var(--text3);padding:3px 8px;background:var(--bg3);border:1px solid var(--border);border-radius:6px;white-space:nowrap}
.tb-stat b{color:var(--p600);font-weight:600}
.spacer{flex:1}
.env-sw{display:flex;gap:2px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:2px;flex-shrink:0}
.env-btn{font-size:9px;font-weight:700;padding:3px 9px;border-radius:6px;cursor:pointer;color:var(--text3);border:none;background:transparent;font-family:var(--mono);letter-spacing:.5px;transition:all .2s}
.env-btn.on{background:linear-gradient(135deg,var(--p700),var(--p500));color:#fff;box-shadow:0 2px 8px rgba(126,34,206,.25)}
.tb-btn{
  background:var(--bg2);border:1px solid var(--border);border-radius:7px;
  color:var(--text2);font-size:11px;font-weight:600;padding:5px 12px;
  cursor:pointer;font-family:var(--sans);transition:all .2s;display:flex;align-items:center;gap:5px;
  white-space:nowrap;flex-shrink:0;
}
.tb-btn:hover{border-color:var(--p300);color:var(--p700);background:var(--p50)}

/* ══════════════════════════ LAYOUT ══════════════════════════ */
.app{display:flex;height:calc(100vh - 48px);overflow:hidden;position:relative}

/* ══════════════════════════ SIDEBAR ══════════════════════════ */
.sidebar{
  width:230px;flex-shrink:0;display:flex;flex-direction:column;
  background:#fff;border-right:1px solid var(--border);
  overflow:hidden;position:relative;
  min-width:46px;max-width:360px;
}
.sb-hd{padding:10px 12px 6px;flex-shrink:0;display:flex;align-items:center;justify-content:space-between}
.sb-title{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--text3)}
.sb-search-wrap{padding:0 8px 6px;flex-shrink:0}
.sb-search{display:flex;align-items:center;gap:6px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:5px 8px}
.sb-search svg{width:12px;height:12px;color:var(--text3);flex-shrink:0}
.sb-search input{flex:1;border:none;background:transparent;outline:none;font-size:11px;font-family:var(--sans);color:var(--text)}
.sb-search input::placeholder{color:var(--text3)}
.sb-list{flex:1;overflow-y:auto;padding-bottom:12px}
.sb-sec{padding:10px 12px 4px;font-size:8px;font-weight:700;letter-spacing:2px;color:var(--text3);text-transform:uppercase;flex-shrink:0}
.sb-item{
  display:flex;align-items:center;gap:8px;padding:6px 12px;
  cursor:pointer;font-size:11px;font-weight:500;color:var(--text2);
  border-left:2px solid transparent;transition:all .15s;overflow:hidden;
  user-select:none;white-space:nowrap;
}
.sb-item:hover{color:var(--p700);background:var(--p50);border-left-color:var(--p300)}
.sb-item.act{color:var(--p700);background:var(--p100);border-left-color:var(--p500);font-weight:600}
.sb-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.sb-lbl{flex:1;overflow:hidden;text-overflow:ellipsis}
.sb-method{font-size:7px;padding:1px 5px;border-radius:4px;font-family:var(--mono);font-weight:700;flex-shrink:0}
.mpost{background:var(--p100);color:var(--p700);border:1px solid var(--p200)}
.mget{background:var(--ok-bg);color:var(--ok);border:1px solid var(--ok-border)}
.sb-tag{font-size:7px;padding:1px 5px;border-radius:4px;background:var(--bg3);color:var(--text3);font-family:var(--mono);border:1px solid var(--border);flex-shrink:0}
.workflow-banner{
  margin:6px 8px;padding:10px 12px;
  background:linear-gradient(135deg,var(--warn-bg),#fff8ed);
  border:1px solid #fed7aa;border-radius:8px;
  font-family:var(--mono);font-size:9px;color:#92400e;line-height:1.7;flex-shrink:0;
}
.workflow-banner b{display:block;font-size:8px;letter-spacing:1px;margin-bottom:4px;color:var(--warn)}

/* ══════════════════════════ V-RESIZE HANDLE ══════════════════════════ */
.v-res{
  width:5px;cursor:col-resize;flex-shrink:0;position:relative;z-index:10;
  background:transparent;transition:background .2s;
}
.v-res:hover{background:rgba(168,85,247,.15)}
.v-res::after{
  content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  width:2px;height:32px;border-radius:1px;background:var(--border2);opacity:.5;
  transition:all .2s;
}
.v-res:hover::after{background:var(--p400);opacity:1}

/* ══════════════════════════ CENTER ══════════════════════════ */
.center{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0;background:var(--bg2)}

/* mode tabs */
.mode-tabs{
  display:flex;align-items:center;background:#fff;border-bottom:1px solid var(--border);
  flex-shrink:0;padding:0 8px;gap:2px;
}
.mode-tab{
  padding:0 14px;height:42px;display:flex;align-items:center;gap:5px;
  font-size:12px;font-weight:600;color:var(--text3);cursor:pointer;
  border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap;
}
.mode-tab:hover{color:var(--text2)}
.mode-tab.act{color:var(--p700);border-bottom-color:var(--p500)}
.mode-tab-icon{font-size:14px}

/* ══════════════════════════ SINGLE MODE ══════════════════════════ */
#mSingle{flex:1;display:flex;flex-direction:column;overflow:hidden}
.url-bar{
  display:flex;align-items:center;gap:8px;padding:8px 12px;
  background:#fff;border-bottom:1px solid var(--border);flex-shrink:0;
}
.method-sel{
  background:var(--p100);border:1.5px solid var(--p300);color:var(--p700);
  font-family:var(--mono);font-size:10px;font-weight:700;padding:6px 8px;border-radius:7px;
  outline:none;cursor:pointer;flex-shrink:0;transition:all .2s;
}
.method-sel option{background:#fff;color:var(--text)}
.url-inp{
  flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:8px;
  color:var(--text);font-family:var(--mono);font-size:10.5px;padding:7px 12px;
  outline:none;min-width:0;transition:all .2s;
}
.url-inp:focus{border-color:var(--p400);background:var(--p50);box-shadow:0 0 0 3px rgba(168,85,247,.1)}
.send-btn{
  background:linear-gradient(135deg,var(--p700),var(--p500));color:#fff;
  border:none;border-radius:8px;padding:8px 20px;font-family:var(--sans);
  font-weight:700;font-size:12px;cursor:pointer;white-space:nowrap;
  transition:all .2s;box-shadow:0 4px 12px rgba(126,34,206,.25);flex-shrink:0;
}
.send-btn:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(126,34,206,.4)}
.send-btn:active{transform:none}
.send-btn:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none}

/* req sub-tabs */
.req-tabs{display:flex;align-items:center;background:#fff;border-bottom:1px solid var(--border);flex-shrink:0}
.req-tab{padding:6px 12px;font-size:10px;font-weight:600;color:var(--text3);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;text-transform:uppercase;letter-spacing:.5px}
.req-tab:hover{color:var(--text2)}
.req-tab.act{color:var(--p600);border-bottom-color:var(--p500)}
.req-tab-actions{margin-left:auto;display:flex;gap:4px;padding:0 8px}
.icon-btn{background:var(--bg3);border:1px solid var(--border);border-radius:6px;color:var(--text2);font-size:10px;padding:3px 9px;cursor:pointer;font-family:var(--mono);transition:all .2s}
.icon-btn:hover{border-color:var(--p300);color:var(--p700);background:var(--p50)}

/* split */
.split-wrap{flex:1;display:flex;flex-direction:column;overflow:hidden}
.pane{display:flex;flex-direction:column;overflow:hidden;min-height:60px}
.pane-hdr{display:flex;align-items:center;gap:8px;padding:6px 12px;background:#fff;border-bottom:1px solid var(--border);flex-shrink:0}
.pane-title{font-size:9px;font-weight:700;letter-spacing:1.5px;color:var(--text3);text-transform:uppercase;font-family:var(--mono)}
.code-edit{flex:1;background:var(--bg2);border:none;color:var(--text);font-family:var(--mono);font-size:11px;line-height:1.75;padding:12px;resize:none;outline:none;overflow:auto;width:100%}
.code-edit::placeholder{color:var(--text3)}
.h-drag{height:5px;background:var(--border);cursor:row-resize;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:background .2s;position:relative}
.h-drag::after{content:'';width:36px;height:2px;border-radius:1px;background:var(--text3);opacity:.25;transition:all .2s}
.h-drag:hover{background:rgba(168,85,247,.15)}
.h-drag:hover::after{background:var(--p500);opacity:.8}
.resp-chip{font-family:var(--mono);font-size:9px;padding:2px 8px;border-radius:5px;background:var(--bg3);border:1px solid var(--border);color:var(--text3);white-space:nowrap;transition:all .3s}
.resp-chip.ok{background:var(--ok-bg);color:var(--ok);border-color:var(--ok-border)}
.resp-chip.err{background:var(--err-bg);color:var(--err);border-color:var(--err-border)}
.resp-chip.spin{animation:spin-blink .5s infinite;border-color:var(--p300);color:var(--p600);background:var(--p50)}
@keyframes spin-blink{0%,100%{opacity:1}50%{opacity:.3}}
.resp-ms{font-family:var(--mono);font-size:9px;color:var(--warn);margin-left:4px}
.resp-body{flex:1;overflow:auto;padding:12px;font-family:var(--mono);font-size:11px;line-height:1.75;white-space:pre-wrap;word-break:break-all;background:var(--bg2)}
.jk{color:#7c3aed}.js{color:#16a34a}.jn{color:#d97706}.jb{color:#db2777}.jnull{color:var(--text3)}

/* hint box */
.hint{
  margin:8px 12px;padding:8px 12px;border-radius:8px;
  background:var(--p50);border:1px solid var(--p200);
  font-family:var(--mono);font-size:9px;color:var(--p700);line-height:1.6;
  display:none;flex-shrink:0;
}
.hint.show{display:block}
.hint b{color:var(--p900)}

/* ══════════════════════════ MULTI MODE ══════════════════════════ */
#mMulti{flex:1;display:none;flex-direction:column;overflow:hidden}
.multi-bar{
  display:flex;align-items:center;gap:8px;padding:8px 12px;
  background:#fff;border-bottom:1px solid var(--border);flex-shrink:0;flex-wrap:wrap;
}
.multi-url{
  flex:1;min-width:200px;background:var(--bg3);border:1px solid var(--border);
  border-radius:8px;color:var(--text);font-family:var(--mono);font-size:10.5px;
  padding:7px 12px;outline:none;transition:all .2s;
}
.multi-url:focus{border-color:var(--p400);background:var(--p50)}
.conc-wrap{display:flex;align-items:center;gap:6px;flex-shrink:0}
.conc-lbl{font-size:10px;color:var(--text3);font-family:var(--mono)}
.conc-inp{width:56px;background:var(--bg3);border:1px solid var(--border);border-radius:7px;color:var(--text);font-family:var(--mono);font-size:11px;padding:5px 8px;outline:none;text-align:center;transition:all .2s}
.conc-inp:focus{border-color:var(--p400)}
.fire-btn{
  background:linear-gradient(135deg,var(--p700),var(--p400));color:#fff;
  border:none;border-radius:8px;padding:8px 20px;font-family:var(--sans);
  font-weight:700;font-size:12px;cursor:pointer;white-space:nowrap;
  transition:all .2s;box-shadow:0 4px 12px rgba(126,34,206,.25);flex-shrink:0;
}
.fire-btn:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 6px 20px rgba(126,34,206,.4)}
.fire-btn:disabled{opacity:.4;cursor:not-allowed}
.prog-wrap{display:flex;align-items:center;gap:8px;min-width:120px}
.prog-track{flex:1;height:4px;background:var(--p100);border-radius:2px;overflow:hidden}
.prog-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--p700),var(--p400));border-radius:2px;transition:width .3s}
.prog-txt{font-family:var(--mono);font-size:9px;color:var(--text3);white-space:nowrap}
.add-slot-btn{background:var(--bg3);border:1px dashed var(--border2);border-radius:7px;color:var(--text2);font-size:11px;font-weight:600;padding:7px 14px;cursor:pointer;font-family:var(--sans);transition:all .2s;white-space:nowrap;flex-shrink:0}
.add-slot-btn:hover{border-color:var(--p400);color:var(--p700);background:var(--p50)}

/* slots */
.slots-area{flex:1;display:flex;overflow:hidden}
.slots-scroll{flex:1;display:flex;gap:1px;overflow-x:auto;overflow-y:hidden;background:var(--border)}
.slot{flex:0 0 320px;min-width:240px;background:#fff;display:flex;flex-direction:column;overflow:hidden;position:relative}
.slot-resizer{position:absolute;right:0;top:0;bottom:0;width:5px;cursor:col-resize;z-index:5;background:transparent;transition:background .2s}
.slot-resizer:hover,.slot-resizer.dragging{background:rgba(168,85,247,.2)}
.slot-hd{display:flex;align-items:center;gap:6px;padding:8px 10px;background:var(--bg2);border-bottom:1px solid var(--border);flex-shrink:0}
.slot-num{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:800;flex-shrink:0;font-family:var(--mono)}
.slot-sel{flex:1;background:#fff;border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:10.5px;padding:3px 6px;outline:none;cursor:pointer;font-family:var(--sans);font-weight:500;transition:all .2s}
.slot-sel:focus{border-color:var(--p400)}
.slot-sel option{background:#fff}
.slot-status{font-family:var(--mono);font-size:9px;white-space:nowrap;flex-shrink:0}
.slot-close{background:none;border:none;color:var(--text3);cursor:pointer;font-size:14px;padding:2px 4px;border-radius:4px;transition:all .2s;flex-shrink:0;line-height:1}
.slot-close:hover{color:var(--err);background:var(--err-bg)}
.slot-pan-row{display:flex;align-items:center;gap:4px;padding:5px 10px;background:var(--p50);border-bottom:1px solid var(--border);flex-shrink:0}
.pan-lbl{font-size:8px;color:var(--p700);font-family:var(--mono);font-weight:600;flex-shrink:0}
.pan-inp{flex:1;background:#fff;border:1px solid var(--p200);border-radius:5px;color:var(--p800);font-family:var(--mono);font-size:9px;padding:3px 6px;outline:none;transition:border-color .2s}
.pan-inp:focus{border-color:var(--p400)}
.pin-inp{width:80px;background:#fff;border:1px solid var(--p200);border-radius:5px;color:var(--p800);font-family:var(--mono);font-size:9px;padding:3px 6px;outline:none;transition:border-color .2s}
.pin-inp:focus{border-color:var(--p400)}
.slot-body{flex:1;display:flex;flex-direction:column;overflow:hidden}
.slot-req{flex:1;min-height:80px;overflow:hidden;display:flex;flex-direction:column}
.slot-req textarea{flex:1;background:var(--bg2);border:none;color:var(--text);font-family:var(--mono);font-size:9.5px;line-height:1.65;padding:8px 10px;resize:none;outline:none;overflow:auto}
.slot-h-drag{height:4px;background:var(--border);cursor:row-resize;flex-shrink:0;transition:background .2s;display:flex;align-items:center;justify-content:center}
.slot-h-drag:hover{background:rgba(168,85,247,.2)}
.slot-h-drag::after{content:'';width:28px;height:2px;border-radius:1px;background:var(--text3);opacity:.2}
.slot-resp{flex:1;min-height:60px;display:flex;flex-direction:column;overflow:hidden}
.slot-resp-hd{display:flex;align-items:center;gap:6px;padding:5px 10px;background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);flex-shrink:0}
.slot-pill{font-family:var(--mono);font-size:8px;padding:2px 6px;border-radius:4px;background:var(--bg3);border:1px solid var(--border);color:var(--text3);white-space:nowrap}
.slot-pill.ok{background:var(--ok-bg);color:var(--ok);border-color:var(--ok-border)}
.slot-pill.err{background:var(--err-bg);color:var(--err);border-color:var(--err-border)}
.slot-pill.spin{animation:spin-blink .5s infinite;background:var(--p50);border-color:var(--p300);color:var(--p600)}
.slot-ms{font-family:var(--mono);font-size:8px;color:var(--warn)}
.slot-resp-body{flex:1;overflow:auto;padding:8px 10px;font-family:var(--mono);font-size:9.5px;line-height:1.65;white-space:pre-wrap;word-break:break-all;background:var(--bg2)}

/* ══════════════════════════ SCENARIO MODE ══════════════════════════ */
#mScenario{flex:1;display:none;flex-direction:column;overflow:hidden}
.scen-hd{display:flex;align-items:center;gap:12px;padding:10px 14px;background:#fff;border-bottom:1px solid var(--border);flex-shrink:0}
.scen-body{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:6px}
.scen-step{display:flex;align-items:center;gap:10px;padding:10px 14px;background:#fff;border:1px solid var(--border);border-radius:10px;transition:all .2s;box-shadow:var(--shadow)}
.scen-step:hover{border-color:var(--p300);box-shadow:var(--shadow2)}
.step-num{width:24px;height:24px;border-radius:50%;flex-shrink:0;background:var(--p100);border:1.5px solid var(--p300);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:800;color:var(--p700);font-family:var(--mono)}
.step-sel{flex:1;background:var(--bg3);border:1px solid var(--border);border-radius:7px;color:var(--text);font-size:11px;padding:4px 8px;outline:none;cursor:pointer;font-family:var(--sans)}
.step-sel option{background:#fff}
.step-res{font-family:var(--mono);font-size:9px;padding:2px 7px;border-radius:5px;white-space:nowrap}
.step-res.ok{background:var(--ok-bg);color:var(--ok)}
.step-res.err{background:var(--err-bg);color:var(--err)}
.step-res.run{background:var(--p50);color:var(--p600);animation:spin-blink .8s infinite}
.step-arrow{text-align:center;color:var(--text3);font-size:18px;line-height:1}
.scen-foot{padding:10px 14px;border-top:1px solid var(--border);background:#fff;display:flex;gap:8px;align-items:center;flex-shrink:0}

/* ══════════════════════════ ERRORS MODE ══════════════════════════ */
#mErrors{flex:1;display:none;flex-direction:column;overflow:hidden}
.err-hd{padding:10px 14px;background:#fff;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;gap:10px}
.err-grid{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:6px}
.err-row{display:flex;align-items:center;gap:12px;padding:10px 14px;background:#fff;border:1px solid var(--border);border-radius:9px;cursor:default;transition:all .2s;box-shadow:var(--shadow)}
.err-row:hover{border-color:var(--p300);background:var(--p50)}
.err-code{font-family:var(--mono);font-size:10px;font-weight:600;color:var(--err);min-width:220px;flex-shrink:0}
.err-desc{font-size:11px;color:var(--text2);flex:1}
.err-sev{font-size:8px;padding:2px 7px;border-radius:4px;font-family:var(--mono);font-weight:700;flex-shrink:0}
.sev-HIGH{background:var(--err-bg);color:var(--err);border:1px solid var(--err-border)}
.sev-MED{background:var(--warn-bg);color:var(--warn);border:1px solid #fed7aa}
.sev-LOW{background:var(--ok-bg);color:var(--ok);border:1px solid var(--ok-border)}

/* ══════════════════════════ ACCOUNTS MODE ══════════════════════════ */
#mAccounts{flex:1;display:none;flex-direction:column;overflow:hidden}
.acc-grid{flex:1;overflow:auto;padding:14px;position:relative;background:var(--bg2)}
.acc-card{background:#fff;border:1px solid var(--border);border-radius:12px;overflow:auto;box-shadow:var(--shadow);transition:border-color .2s,box-shadow .2s;resize:both;position:absolute;min-width:280px;min-height:100px;display:flex;flex-direction:column}
.acc-card:hover{border-color:var(--p300);box-shadow:var(--shadow2)}
.acc-card-hd{padding:12px 14px;background:var(--bg2);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.acc-card-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.acc-card-title{font-size:13px;font-weight:700;color:var(--text)}
.acc-card-sub{font-size:9px;color:var(--text3);font-family:var(--mono);margin-top:1px}
.acc-card-body{padding:14px;display:flex;flex-direction:column;flex:1}
.acc-field{margin-bottom:10px}
.acc-field label{display:block;font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text3);font-family:var(--mono);margin-bottom:4px}
.acc-field input,.acc-field select{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:7px;color:var(--text);font-family:var(--mono);font-size:10px;padding:6px 9px;outline:none;transition:all .2s}
.acc-field input:focus,.acc-field select:focus{border-color:var(--p400);background:var(--p50);box-shadow:0 0 0 3px rgba(168,85,247,.1)}
.acc-field select option{background:#fff}
.acc-send{width:100%;background:linear-gradient(135deg,var(--p700),var(--p500));color:#fff;border:none;border-radius:8px;padding:8px 0;font-family:var(--sans);font-weight:700;font-size:11px;cursor:pointer;transition:all .2s;letter-spacing:.3px}
.acc-send:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(126,34,206,.3)}
.acc-send:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none}
.acc-resp{margin-top:10px;background:var(--bg2);border:1px solid var(--border);border-radius:7px;padding:8px;font-family:var(--mono);font-size:9px;line-height:1.6;white-space:pre-wrap;word-break:break-all;max-height:none;flex:1;overflow-y:auto;display:none;color:var(--text2)}
.acc-resp.show{display:block}
.acc-resp.ok{background:var(--ok-bg);border-color:var(--ok-border);color:var(--ok)}
.acc-resp.err{background:var(--err-bg);border-color:var(--err-border);color:var(--err)}

/* ══════════════════════════ RIGHT PANEL ══════════════════════════ */
.right{width:250px;flex-shrink:0;min-width:0;display:flex;flex-direction:column;background:#fff;border-left:1px solid var(--border);overflow:hidden;transition:width .3s;min-width:0;max-width:400px}
.right.closed{width:0;border-left:none;overflow:hidden}
.rp-tabs{display:flex;border-bottom:1px solid var(--border);flex-shrink:0}
.rp-tab{flex:1;padding:10px 6px;font-size:9px;font-weight:700;color:var(--text3);cursor:pointer;text-align:center;border-bottom:2px solid transparent;transition:all .2s;text-transform:uppercase;letter-spacing:.5px}
.rp-tab:hover{color:var(--text2)}
.rp-tab.act{color:var(--p600);border-bottom-color:var(--p500)}
.rp-body{flex:1;overflow-y:auto;padding:12px}
.metric{background:var(--bg2);border:1px solid var(--border);border-radius:9px;padding:10px 12px;margin-bottom:8px;transition:all .2s}
.metric:hover{border-color:var(--p200);background:var(--p50)}
.metric-lbl{font-size:8px;font-weight:700;letter-spacing:1.5px;color:var(--text3);text-transform:uppercase;font-family:var(--mono);margin-bottom:4px}
.metric-val{font-size:22px;font-weight:800;color:var(--p700);line-height:1.2;font-family:var(--mono)}
.metric-sub{font-size:9px;color:var(--text3);font-family:var(--mono);margin-top:3px}
.mini-bars{height:24px;display:flex;align-items:flex-end;gap:2px;margin-top:6px}
.mini-bar{flex:1;border-radius:2px 2px 0 0;min-height:2px;background:linear-gradient(180deg,var(--p500),var(--p300));opacity:.5;transition:height .4s}
.hist-item{display:flex;align-items:center;gap:8px;padding:6px 8px;border:1px solid var(--border);border-radius:7px;margin-bottom:4px;transition:all .2s;background:#fff}
.hist-item:hover{border-color:var(--p200);background:var(--p50)}
.hist-badge{font-size:7px;font-weight:700;padding:2px 5px;border-radius:4px;white-space:nowrap;font-family:var(--mono)}
.bOk{background:var(--ok-bg);color:var(--ok);border:1px solid var(--ok-border)}
.bErr{background:var(--err-bg);color:var(--err);border:1px solid var(--err-border)}
.hist-ch{font-size:10px;font-weight:600;color:var(--text2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.hist-id{font-size:8px;color:var(--text3);font-family:var(--mono)}

/* ══════════════════════════ NOTIFICATIONS ══════════════════════════ */
#notifs{position:fixed;top:56px;right:14px;z-index:9000;display:flex;flex-direction:column;gap:6px;pointer-events:none}
.notif{display:flex;align-items:flex-start;gap:10px;padding:10px 12px;border-radius:10px;min-width:240px;max-width:320px;background:#fff;border:1px solid var(--border);box-shadow:var(--shadow2);pointer-events:all;transform:translateX(110%);opacity:0;transition:all .35s cubic-bezier(.175,.885,.32,1.275)}
.notif.show{transform:translateX(0);opacity:1}
.notif.hide{transform:translateX(110%);opacity:0}
.notif-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:3px}
.notif-content{flex:1;min-width:0}
.notif-title{font-size:12px;font-weight:700;margin-bottom:1px}
.notif-msg{font-size:10px;color:var(--text2);font-family:var(--mono)}
.notif-close{background:none;border:none;color:var(--text3);cursor:pointer;font-size:14px;flex-shrink:0;padding:0;line-height:1;transition:color .2s}
.notif-close:hover{color:var(--text)}
.nok .notif-dot{background:var(--ok)} .nok .notif-title{color:var(--ok)} .nok{border-color:var(--ok-border)}
.nerr .notif-dot{background:var(--err)} .nerr .notif-title{color:var(--err)} .nerr{border-color:var(--err-border)}
.nwarn .notif-dot{background:var(--warn)} .nwarn .notif-title{color:var(--warn)} .nwarn{border-color:#fed7aa}
.ninfo .notif-dot{background:var(--p500)} .ninfo .notif-title{color:var(--p700)} .ninfo{border-color:var(--p200)}

/* scrollbar */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--p200);border-radius:2px}
::-webkit-scrollbar-thumb:hover{background:var(--p300)}
</style>
</head>
<body>

<!-- ═══ SPLASH ═══ -->
