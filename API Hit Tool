  <svg class="circuit-bg" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="lg1" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color:#7e22ce;stop-opacity:.6"/>
        <stop offset="100%" style="stop-color:#c084fc;stop-opacity:.2"/>
