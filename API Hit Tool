}
function setSlotDone(id,ok,code,body,ms){
  const s=slots.find(x=>x.id===id);if(s){s.status=ok?'ok':'err';s.ms=ms;}
  g('slotPill_'+id,e=>{e.textContent=code||'ERR';e.className='slot-pill '+(ok?'ok':'err');});
  g('slotMs_'+id,e=>e.textContent=ms+'ms');
  g('slotResp_'+id,e=>e.innerHTML=typeof body==='object'?highlight(JSON.stringify(body,null,2)):`<span style="color:var(--${ok?'text':'err'})">${esc(String(body))}</span>`);
  g('slotStat_'+id,e=>{e.textContent=ok?'✅':'❌';e.style.color=ok?'var(--ok)':'var(--err)';});
}

