      <div class="step-num">${i+1}</div>
      <select class="step-sel" onchange="scenSteps[${i}]=this.value">
        ${CH_LIST.map(k=>`<option value="${k}" ${k===ch?'selected':''}>${CH_LABELS[k]||k}</option>`).join('')}
      </select>
      <div class="step-res" id="scenR_${i}"></div>
      <button onclick="scenSteps.splice(${i},1);renderScen()" style="background:none;border:none;color:var(--text3);cursor:pointer;padding:2px 6px;border-radius:4px;font-size:14px;transition:all .2s" onmouseover="this.style.color='var(--err)'" onmouseout="this.style.color='var(--text3)'">✕</button>
    </div>
    ${i<scenSteps.length-1?'<div class="step-arrow">↓</div>':''}`).join('');
}
function addScenStep(){scenSteps.push('ATM_WITHDRAWAL');renderScen();}
function clearScen(){scenSteps=[];renderScen();}
async function runScenario(){
  const url=ENV[env]+'/transaction/initiate';
  const delay=parseInt(g2('scenDelay')?.value)||300;
  notify('Scenario Started',scenSteps.length+' steps · '+delay+'ms delay','info',3000);
  for(let i=0;i<scenSteps.length;i++){
    const ch=scenSteps[i];
    const res=g2('scenR_'+i);
    if(res){res.className='step-res run';res.textContent='running…';}
    const payload=JSON.parse(JSON.stringify(PAYLOADS[ch]||{}));
    if(payload.data?.clientTxnId) payload.data.clientTxnId+='-sc-'+Date.now();
    const t0=performance.now();
    try{
      const r=await fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
      const ms=Math.round(performance.now()-t0);
      recordStat(r.ok,ms,CH_LABELS[ch]||ch,r.status);
      if(res){res.className='step-res '+(r.ok?'ok':'err');res.textContent=(r.ok?'✅ ':'❌ ')+r.status+' '+ms+'ms';}
    }catch(e){
      const ms=Math.round(performance.now()-t0);
      recordStat(false,ms,CH_LABELS[ch]||ch,null);
      if(res){res.className='step-res err';res.textContent='❌ NET ERR';}
    }
    if(i<scenSteps.length-1) await new Promise(r=>setTimeout(r,delay));
  }
  notify('Scenario Complete',scenSteps.length+' steps executed','ok',4000);
}

// ═══════════════════════════════════
// STATS
// ═══════════════════════════════════
function recordStat(ok,ms,ch,code){
  stats.total++;if(ok) stats.ok++;else stats.err++;
  stats.lats.push(ms);if(stats.lats.length>30) stats.lats.shift();
  g('sTot',e=>e.textContent=stats.total);
  g('sOk',e=>e.textContent=stats.ok);
  g('sErr',e=>e.textContent=stats.err);
  g('mTot',e=>e.textContent=stats.total);
  const rate=stats.total>0?Math.round(stats.ok/stats.total*100):0;
  g('mRate',e=>e.textContent=rate+'%');
  g('mRateSub',e=>e.textContent=stats.ok+' ok / '+stats.err+' err');
  const avg=stats.lats.length?Math.round(stats.lats.reduce((a,b)=>a+b,0)/stats.lats.length):0;
  g('mLat',e=>e.textContent=avg);
  const recent=stats.lats.slice(-12),mx=Math.max(...recent,1);
  g('mcLat',e=>e.innerHTML=recent.map(v=>`<div class="mini-bar" style="height:${Math.max(2,Math.round(v/mx*22))}px"></div>`).join(''));
  histLog.unshift({ch,code,ms,ok,t:new Date().toLocaleTimeString()});
  if(histLog.length>40) histLog.pop();
  g('histList',e=>e.innerHTML=histLog.slice(0,15).map(h=>`
    <div class="hist-item">
      <span class="hist-badge ${h.ok?'bOk':'bErr'}">${h.code||'ERR'}</span>
      <div style="flex:1;min-width:0">
        <div class="hist-ch">${h.ch}</div>
        <div class="hist-id">${h.t} · ${h.ms}ms</div>
      </div>
    </div>`).join(''));
}

// ═══════════════════════════════════
// HEALTH
// ═══════════════════════════════════
async function pingHealth(){
  try{
    const r=await fetch(ENV[env]+'/health',{signal:AbortSignal.timeout(3000)});
    const was=engineUp;engineUp=r.ok;
    g('engDot',e=>e.className='eng-dot '+(r.ok?'up':'down'));
    g('engLbl',e=>e.textContent=(r.ok?'Online':'Offline')+' · '+env);
    if(was===null) notify(r.ok?'Engine Online':'Engine Offline',r.ok?'Connected to '+ENV[env]:'Cannot reach '+ENV[env],r.ok?'ok':'err',4000);
    else if(was===false&&r.ok) notify('Reconnected!','Engine back online','ok',3500);
  }catch{
    const was=engineUp;engineUp=false;
    g('engDot',e=>e.className='eng-dot down');
    g('engLbl',e=>e.textContent='Offline · '+env);
    if(was===null||was===true) notify('Engine Offline','Cannot reach '+ENV[env],'err',5000);
  }
}

// ═══════════════════════════════════
// MISC
// ═══════════════════════════════════
function clearAll(){
  clearResp();
  document.querySelectorAll('.acc-resp').forEach(e=>{e.className='acc-resp';e.textContent='';});
  slots.forEach(s=>{
    g('slotResp_'+s.id,e=>e.innerHTML='<span style="color:var(--text3)">waiting…</span>');
    g('slotPill_'+s.id,e=>{e.textContent='—';e.className='slot-pill';});
    g('slotMs_'+s.id,e=>e.textContent='');
    g('slotStat_'+s.id,e=>{e.textContent='—';e.style.color='var(--text3)';});
    const sv=slots.find(x=>x.id===s.id);if(sv) sv.status='idle';
  });
  scenSteps=['ISSUER','POS_PURCHASE','MOBILE'];renderScen();
  notify('Cleared','Workspace reset','info',2000);
}
function filterSb(q){document.querySelectorAll('.sb-item').forEach(e=>{e.style.display=!q||e.textContent.toLowerCase().includes(q.toLowerCase())?'':'none';});}
function swRPTab(tab,el){document.querySelectorAll('.rp-tab').forEach(t=>t.classList.remove('act'));el.classList.add('act');g('rp_metrics',e=>e.style.display=tab==='metrics'?'':'none');g('rp_history',e=>e.style.display=tab==='history'?'':'none');}
function g(id,fn){const e=document.getElementById(id);if(e) fn(e);}
function g2(id){return document.getElementById(id);}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function highlight(json){
  return json.replace(/(\"(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*\"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g,m=>{
    let c='jn';
    if(/^"/.test(m)) c=/:$/.test(m)?'jk':'js';
    else if(/true|false/.test(m)) c='jb';
    else if(/null/.test(m)) c='jnull';
    return `<span class="${c}">${esc(m)}</span>`;
  });
}

let nid=0;
function notify(title,msg,type='info',dur=4000){
  const stack=g2('notifs');if(!stack) return;
  const id='n'+(nid++);
  const div=document.createElement('div');
  div.className=`notif n${type}`;div.id=id;
  div.innerHTML=`<div class="notif-dot"></div><div class="notif-content"><div class="notif-title">${esc(title)}</div><div class="notif-msg">${esc(msg)}</div></div><button class="notif-close" onclick="closeN('${id}')">✕</button>`;
  stack.appendChild(div);
  requestAnimationFrame(()=>requestAnimationFrame(()=>div.classList.add('show')));
  setTimeout(()=>closeN(id),dur);
}
function closeN(id){const el=g2(id);if(!el)return;el.classList.remove('show');el.classList.add('hide');setTimeout(()=>el.remove(),380);}

runSplash();
