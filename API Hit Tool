async function sendSingle(){
  const url=g2('urlInp')?.value.trim();
  const method=g2('methodSel')?.value;
  const body=g2('bodyEd')?.value.trim();
  const btn=g2('sendBtn');
  if(btn){btn.disabled=true;btn.textContent='⏳ Sending…';}
  g('respChip',e=>{e.textContent='…';e.className='resp-chip spin';});
  g('respBody',e=>e.innerHTML='<span style="color:var(--p500)">Sending request…</span>');
  g('respMs',e=>e.textContent='');
  const t0=performance.now();
  try{
    const apiKey = CH_APIKEYS[curCh] || 'sk_admin_ROHAN_MASTER_9649';
    const opts={method,headers:{'Content-Type':'application/json','X-API-Key':apiKey}};
    if(method!=='GET'&&body) opts.body=body;
    const resp=await fetch(url,opts);
    const ms=Math.round(performance.now()-t0);
    const text=await resp.text();
    let parsed; try{parsed=JSON.parse(text);}catch{}
    g('respChip',e=>{e.textContent=resp.status+' '+resp.statusText;e.className='resp-chip '+(resp.ok?'ok':'err');});
    g('respMs',e=>e.textContent=ms+' ms');
    g('respBody',e=>e.innerHTML=parsed?highlight(JSON.stringify(parsed,null,2)):esc(text));
    recordStat(resp.ok,ms,CH_LABELS[curCh]||curCh,resp.status);
    notify(resp.ok?'Success':'Request Failed',`${resp.status} · ${ms}ms · ${CH_LABELS[curCh]||curCh}`,resp.ok?'ok':'err',3500);
    if(parsed?.card?.encryptedPan) notify('💡 ISSUER Tip','Copy encryptedPan and expiry '+parsed.card.expiry+' for future requests','warn',8000);
  }catch(e){
    const ms=Math.round(performance.now()-t0);
    g('respChip',el=>{el.textContent='NETWORK ERR';el.className='resp-chip err';});
    g('respMs',el=>el.textContent=ms+' ms');
    g('respBody',el=>el.innerHTML=`<span style="color:var(--err)">⚠ ${esc(e.message)}\n\nEngine unreachable at:\n${url}\n\nCheck:\n  1. Server is running\n  2. CORS enabled (v2.1+)\n  3. Correct ENV selected</span>`);
    recordStat(false,ms,CH_LABELS[curCh]||curCh,null);
    notify('Network Error',e.message,'err',5000);
  }finally{
    if(btn){btn.disabled=false;btn.textContent='Send ⌘↵';}
  }
}
