    stepsEl.appendChild(d);
  });

  let i=0;
  const bar=document.getElementById('spBar');
  function tick(){
    if(i>0){const prev=document.getElementById('spS'+(i-1));if(prev){prev.className='sp-step done';prev.querySelector('.sp-step-dot').style.background='#a855f7';}}
    if(i>=SP_STEPS.length){launch();return;}
    const cur=document.getElementById('spS'+i);
    if(cur) cur.className='sp-step active';
    bar.style.width=Math.round((i+1)/SP_STEPS.length*100)+'%';
    i++;
    setTimeout(tick, 380+Math.random()*150);
  }
  setTimeout(tick, 600);
}

