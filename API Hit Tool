    if(f.t==='number') val=parseFloat(val);
    if(val==='true') val=true;if(val==='false') val=false;
    body[f.k]=val;
  });
  const url=ENV[env]+ep.path;const t0=performance.now();
  try{
    const resp=await fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    const ms=Math.round(performance.now()-t0);const text=await resp.text();let parsed;try{parsed=JSON.parse(text);}catch{}
    if(rEl){rEl.className='acc-resp show '+(resp.ok?'ok':'err');rEl.textContent=parsed?JSON.stringify(parsed,null,2):text;}
    recordStat(resp.ok,ms,ep.title,resp.status);
    notify(resp.ok?'Success':'Failed',`${resp.status} · ${ms}ms · ${ep.title}`,resp.ok?'ok':'err',3000);
  }catch(e){
    if(rEl){rEl.className='acc-resp show err';rEl.textContent='⚠ '+e.message+'\n\n'+url;}
    recordStat(false,Math.round(performance.now()-t0),ep.title,null);
    notify('Network Error',e.message,'err',4000);
  }finally{
    if(btn){btn.disabled=false;btn.textContent='Send Request';}
  }
}

